{
  "author": "SystemSculpt",
  "dependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "async-mutex": "^0.5.0",
    "yaml": "^2.8.1"
  },
  "description": "SystemSculpt AI chat, transcription, semantic search, and Studio workflows inside your vault",
  "devDependencies": {
    "@eslint/json": "^0.14.0",
    "@swc/core": "^1.15.11",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "esbuild": "^0.25.10",
    "eslint": "^9.39.2",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "globals": "^14.0.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "obsidian": "latest",
    "tslib": "2.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "keywords": [],
  "license": "MIT",
  "main": "main.js",
  "name": "systemsculpt-ai",
  "scripts": {
    "prepare": "node scripts/install-git-hooks.mjs",
    "build": "node esbuild.config.mjs production",
    "check": "npm run check:plugin:fast",
    "lint:obsidian": "eslint --cache --cache-location .cache/eslint/source.cache -c eslint.config.mjs --max-warnings 0 \"src/**/*.{ts,tsx,mts,cts}\"",
    "lint:obsidian:fix": "npm run lint:obsidian -- --fix",
    "lint:obsidian:meta": "eslint --cache --cache-location .cache/eslint/meta.cache -c eslint.meta.config.mjs --max-warnings 0 manifest.json LICENSE",
    "check:plugin:obsidian": "npm run lint:obsidian && npm run lint:obsidian:meta",
    "lint:css": "node scripts/lint-css.mjs",
    "test:ui:focused": "node scripts/jest.mjs --config jest.config.cjs --runInBand --runTestsByPath src/core/ui/surface/__tests__/PluginSurface.test.ts src/core/ui/surface/__tests__/SurfacePrimitives.test.ts src/core/ui/surface/__tests__/SurfaceTabs.test.ts src/core/ui/surface/__tests__/SurfaceCombobox.test.ts src/core/ui/surface/__tests__/SurfaceRadioGroup.test.ts src/core/ui/surface/__tests__/SurfaceDomContext.test.ts src/components/__tests__/HoverShell.test.ts src/components/__tests__/EmbeddingsStatusBar.test.ts src/core/ui/progress/__tests__/OperationProgressPanel.test.ts src/core/ui/modals/standard/__tests__/StandardModal.test.ts src/core/ui/modals/__tests__/PromptModal.test.ts src/modals/__tests__/AutomationRunnerModal.test.ts src/modals/__tests__/JanitorModal.test.ts src/modals/__tests__/JanitorConfirmationListModal.test.ts src/modals/__tests__/SystemSculptSearchModal.test.ts src/modals/__tests__/StandardChatSettingsModal.test.ts src/modals/__tests__/RecorderAdvancedModal.test.ts src/__tests__/main-initialize-basic-ui.test.ts src/__tests__/main-initialize-managers.test.ts src/__tests__/settings-recorder-tab.test.ts src/__tests__/systemsculpt-context-menu.test.ts src/__tests__/systemsculpt-settings-tab.test.ts src/services/recorder/__tests__/MicrophoneDeviceCatalog.test.ts src/views/chatview/__tests__/agent-workspace-ui.test.ts src/views/chatview/__tests__/resume-chat-service.test.ts src/views/__tests__/EmbeddingsPresentation.test.ts src/views/history/__tests__/SystemSculptHistoryModal.test.ts src/editor/__tests__/relative-line-numbers.test.ts src/views/studio/__tests__/studio-view-plugin-surface.test.ts src/views/studio/__tests__/studio-clipboard-and-drop-controller.test.ts src/views/studio/systemsculpt-studio-view/__tests__/StudioProjectSessionController.test.ts src/views/studio/__tests__/StudioSearchableDropdown.test.ts src/views/studio/__tests__/studio-context-menu-accessibility.test.ts src/views/studio/__tests__/studio-group-color-palette-accessibility.test.ts src/views/studio/graph-v3/__tests__/studio-graph-image-inline-editor.test.ts src/views/studio/graph-v3/studio-image-editor/__tests__/StudioImageEditorModel.test.ts src/views/studio/graph-v3/studio-image-editor/__tests__/StudioImageEditorCanvas.test.ts",
    "check:ui": "node --test scripts/lint-css.test.mjs scripts/ui-architecture.test.mjs && npm run test:ui:focused",
    "check:plugin": "node scripts/check-plugin.mjs",
    "check:plugin:fast": "node scripts/check-plugin.mjs --fast",
    "check:types": "tsc --noEmit --skipLibCheck --incremental --tsBuildInfoFile .cache/tsc.check.tsbuildinfo",
    "check:mobile": "node --test scripts/mobile-compatibility.test.mjs",
    "check:full": "npm run check:plugin && npm test && npm run test:embeddings && npm run test:integration && npm run test:release-script",
    "check:all": "npm run check:full",
    "dev": "node esbuild.config.mjs",
    "sync:local": "node scripts/sync-local-vaults.mjs",
    "test": "node scripts/jest.mjs --config jest.config.cjs --passWithNoTests",
    "test:strict": "node scripts/jest.mjs --strict-console --config jest.config.cjs --passWithNoTests",
    "test:debug": "node scripts/jest.mjs --debug-console --config jest.config.cjs --passWithNoTests",
    "test:serial": "node scripts/jest.mjs --config jest.config.cjs --runInBand --passWithNoTests",
    "test:watch": "node scripts/jest.mjs --config jest.config.cjs --watch",
    "test:changed": "node scripts/jest.mjs --config jest.config.cjs --onlyChanged --passWithNoTests",
    "test:related": "node scripts/jest.mjs --config jest.config.cjs --findRelatedTests --passWithNoTests",
    "test:leaks": "node scripts/jest.mjs --config jest.config.cjs --maxWorkers=1 --openHandlesTimeout=200 --passWithNoTests",
    "test:embeddings": "node scripts/jest.mjs --config jest.embeddings.config.cjs --passWithNoTests",
    "test:integration": "npm run build && npm run test:integration:ci",
    "test:integration:ci": "node scripts/jest.mjs --config jest.integration.config.cjs --runInBand",
    "test:embeddings:serial": "node scripts/jest.mjs --config jest.embeddings.config.cjs --runInBand --passWithNoTests",
    "test:release-script": "node --test scripts/plugin-build-options.test.mjs scripts/plugin-artifacts.test.mjs scripts/release-plugin.test.mjs",
    "release:plugin": "node scripts/release-plugin.mjs"
  },
  "type": "module",
  "version": "6.0.2"
}
