{
  "author": "",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.63.1",
    "@codemirror/gutter": "^0.19.9",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@openai/codex": "^0.41.0",
    "@openai/codex-sdk": "^0.50.0",
    "@types/stream-json": "^1.7.8",
    "async-mutex": "^0.5.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.1",
    "cors": "^2.8.5",
    "dompurify": "^3.2.7",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "fastmcp": "^3.18.0",
    "figlet": "^1.9.3",
    "fuse.js": "^7.1.0",
    "gradient-string": "^3.0.0",
    "helmet": "^8.1.0",
    "inquirer": "^12.9.6",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.2.2",
    "openai": "^5.23.0",
    "ora": "^9.0.0",
    "stream-json": "^1.9.1",
    "string-similarity": "^4.0.4",
    "yaml": "^2.8.1"
  },
  "description": "An AI-powered plugin for Obsidian",
  "devDependencies": {
    "@swc/core": "^1.15.11",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/string-similarity": "^4.0.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.10",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "obsidian": "latest",
    "ts-node": "^10.9.2",
    "tslib": "2.8.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "keywords": [],
  "license": "MIT",
  "main": "main.js",
  "name": "systemsculpt-ai",
  "scripts": {
    "prepare": "node scripts/install-git-hooks.mjs",
    "build": "node esbuild.config.mjs production",
    "check": "npm run check:plugin",
    "lint:css": "node scripts/lint-css.mjs",
    "check:plugin": "node scripts/check-plugin.mjs",
    "check:plugin:fast": "node scripts/check-plugin.mjs --fast",
    "check:types": "tsc --noEmit --skipLibCheck",
    "check:egress": "node scripts/network-egress-inventory.mjs current --fixture testing/fixtures/managed/egress-baseline-660e7fe.json",
    "check:egress:verify": "node scripts/network-egress-inventory.mjs verify --fixture testing/fixtures/managed/egress-baseline-660e7fe.json",
    "check:all": "npm run check:plugin && npm test",
    "dev": "node esbuild.config.mjs",
    "devmode": "node scripts/toggle-devmode.mjs",
    "sync:local": "node scripts/sync-local-vaults.mjs",
    "test": "node scripts/jest.mjs --config jest.config.cjs --passWithNoTests",
    "test:strict": "node scripts/jest.mjs --strict-console --config jest.config.cjs --passWithNoTests",
    "test:debug": "node scripts/jest.mjs --debug-console --config jest.config.cjs --passWithNoTests",
    "test:serial": "node scripts/jest.mjs --config jest.config.cjs --runInBand --passWithNoTests",
    "test:watch": "node scripts/jest.mjs --config jest.config.cjs --watch",
    "test:changed": "node scripts/jest.mjs --config jest.config.cjs --onlyChanged --passWithNoTests",
    "test:related": "node scripts/jest.mjs --config jest.config.cjs --findRelatedTests --passWithNoTests",
    "test:leaks": "node scripts/jest.mjs --config jest.config.cjs --maxWorkers=1 --openHandlesTimeout=200 --passWithNoTests",
    "test:embeddings": "node scripts/jest.mjs --config jest.embeddings.config.cjs --passWithNoTests",
    "test:integration": "npm run build && npm run test:integration:ci",
    "test:integration:ci": "node scripts/jest.mjs --config jest.integration.config.cjs --runInBand --forceExit",
    "test:embeddings:serial": "node scripts/jest.mjs --config jest.embeddings.config.cjs --runInBand --passWithNoTests",
    "test:release-script": "node --test scripts/release-plugin.test.mjs scripts/check-release-surfaces.test.mjs",
    "test:reload": "node --test scripts/obsidian-reload/*.test.mjs",
    "test:egress-analyzer": "node --test scripts/network-egress-inventory.test.mjs",
    "check:release-surfaces": "node scripts/check-release-surfaces.mjs",
    "release:plugin": "node scripts/release-plugin.mjs"
  },
  "ts-node": {
    "experimentalSpecifierResolution": "node",
    "files": true
  },
  "type": "module",
  "version": "5.11.0"
}
