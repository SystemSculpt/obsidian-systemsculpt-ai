  "description": "An AI-powered plugin for Obsidian",
  "devDependencies": {
    "@swc/core": "^1.15.11",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/string-similarity": "^4.0.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.10",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "obsidian": "latest",
    "ts-node": "^10.9.2",
    "tslib": "2.8.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "keywords": [],
  "license": "MIT",
  "main": "main.js",
  "name": "systemsculpt-ai",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "check": "npm run check:plugin",
    "lint:css": "node scripts/lint-css.mjs",
    "check:plugin": "node scripts/check-plugin.mjs",
    "check:plugin:fast": "node scripts/check-plugin.mjs --fast",
    "check:all": "npm run check:plugin && npm test",
    "dev": "node esbuild.config.mjs",
    "devmode": "node scripts/toggle-devmode.mjs",
    "test:native:desktop": "node testing/native/desktop-automation/run.mjs",
    "test:native:desktop:extended": "node testing/native/desktop-automation/run.mjs --case extended",
    "test:native:desktop:stress": "node testing/native/desktop-automation/run.mjs --case extended --repeat 3 --pause-ms 2000",
    "test:native:android": "node testing/native/runtime-smoke/run.mjs --mode android",
    "test:native:android:extended": "node testing/native/runtime-smoke/run.mjs --mode android --case extended",
    "test:native:android:stress": "node testing/native/runtime-smoke/run.mjs --mode android --case extended --repeat 3 --pause-ms 2000",
    "test:native:ios": "node testing/native/runtime-smoke/run.mjs --mode ios --target-hint Obsidian",
    "test:native:android:sync": "node testing/native/device/android/sync-plugin.mjs",
    "test:native:android:debug:open": "node testing/native/device/android/open-debug-tools.mjs",
    "test:native:android:logcat": "node testing/native/device/android/logcat.mjs",
    "test:native:ios:debug:open": "node testing/native/device/ios/open-debug-tools.mjs",
    "test:native:ios:inspect:plugin": "node testing/native/device/ios/inspect-plugin-state.mjs",
    "test:native:ios:inspect:toggle": "node testing/native/device/ios/inspect-plugin-state.mjs --strict --community-toggle",
    "test:native:ios:appium": "node testing/native/device/ios/start-appium.mjs",
    "android:debug:open": "node testing/native/device/android/open-debug-tools.mjs",
    "android:logcat": "node testing/native/device/android/logcat.mjs",
    "android:smoke:runtime:extended": "node testing/native/runtime-smoke/run.mjs --mode android --case extended",
    "android:smoke:runtime:stress": "node testing/native/runtime-smoke/run.mjs --mode android --case extended --repeat 3 --pause-ms 2000",
    "android:smoke:runtime": "node testing/native/runtime-smoke/run.mjs --mode android",
    "android:sync": "node testing/native/device/android/sync-plugin.mjs",
    "ios:debug:open": "node testing/native/device/ios/open-debug-tools.mjs",
    "ios:inspect:plugin": "node testing/native/device/ios/inspect-plugin-state.mjs",
    "ios:inspect:toggle": "node testing/native/device/ios/inspect-plugin-state.mjs --strict --community-toggle",
    "ios:appium": "node testing/native/device/ios/start-appium.mjs",
    "ios:smoke:runtime": "node testing/native/runtime-smoke/run.mjs --mode ios --target-hint Obsidian",
    "runtime:smoke:desktop:extended": "node testing/native/desktop-automation/run.mjs --case extended",
    "runtime:smoke:desktop:stress": "node testing/native/desktop-automation/run.mjs --case extended --repeat 3 --pause-ms 2000",
    "runtime:smoke": "node testing/native/runtime-smoke/run.mjs",
    "runtime:smoke:desktop": "node testing/native/desktop-automation/run.mjs",
    "sync:local": "node scripts/sync-local-vaults.mjs",
    "test": "node scripts/jest.mjs --config jest.config.cjs --passWithNoTests",
    "test:strict": "node scripts/jest.mjs --strict-console --config jest.config.cjs --passWithNoTests",
    "test:debug": "node scripts/jest.mjs --debug-console --config jest.config.cjs --passWithNoTests",
    "test:serial": "node scripts/jest.mjs --config jest.config.cjs --runInBand --passWithNoTests",
    "test:watch": "node scripts/jest.mjs --config jest.config.cjs --watch",
    "test:changed": "node scripts/jest.mjs --config jest.config.cjs --onlyChanged --passWithNoTests",
    "test:related": "node scripts/jest.mjs --config jest.config.cjs --findRelatedTests --passWithNoTests",
    "test:leaks": "node scripts/jest.mjs --config jest.config.cjs --maxWorkers=1 --openHandlesTimeout=200 --passWithNoTests",
    "test:embeddings": "node scripts/jest.mjs --config jest.embeddings.config.cjs --passWithNoTests",
    "test:embeddings:serial": "node scripts/jest.mjs --config jest.embeddings.config.cjs --runInBand --passWithNoTests",
    "release:plugin": "node scripts/release-plugin.mjs"
  },
  "ts-node": {
    "experimentalSpecifierResolution": "node",
    "files": true
  },
  "type": "module",
  "version": "5.2.0"
}
