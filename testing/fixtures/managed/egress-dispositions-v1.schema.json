{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "network-egress-dispositions-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "ledgerVersion", "historicalFixture", "semanticCatalog", "transitions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "ledgerVersion": { "const": "network-egress-dispositions-v1" },
    "historicalFixture": { "$ref": "#/$defs/anchor" },
    "semanticCatalog": {
      "allOf": [
        { "$ref": "#/$defs/anchor" },
        {
          "type": "object",
          "required": ["mappingCount", "mappingSha256"],
          "properties": {
            "mappingCount": { "type": "integer", "minimum": 0 },
            "mappingSha256": { "$ref": "#/$defs/sha256" }
          }
        }
      ]
    },
    "transitions": { "type": "array", "items": { "$ref": "#/$defs/transition" } }
  },
  "$defs": {
    "sha1": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "nullableSha1": { "anyOf": [{ "$ref": "#/$defs/sha1" }, { "type": "null" }] },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "gitBlob", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "gitBlob": { "$ref": "#/$defs/sha1" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "beforeGitBlobOrNull", "afterGitBlobOrNull"],
      "properties": {
        "path": { "type": "string", "pattern": "^src/" },
        "beforeGitBlobOrNull": { "$ref": "#/$defs/nullableSha1" },
        "afterGitBlobOrNull": { "$ref": "#/$defs/nullableSha1" }
      }
    },
    "predecessorLedger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gitBlob", "sha256", "transitionCount", "finalTransitionHash"],
      "properties": {
        "gitBlob": { "$ref": "#/$defs/sha1" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "transitionCount": { "type": "integer", "minimum": 0 },
        "finalTransitionHash": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "historicalRecordId", "v2OccurrenceId", "ownerPlan", "from", "to", "predecessorSourceTree", "stagedSourceTree", "sourceEvidence", "predecessorLedger", "previousTransitionHash", "transitionHash"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "historicalRecordId": { "$ref": "#/$defs/sha256" },
        "v2OccurrenceId": { "$ref": "#/$defs/sha256" },
        "ownerPlan": { "type": "string", "pattern": "^0(?:16|17|18|20|21|22|23|26|26a|27|27a|30|31)$" },
        "from": { "const": "present" },
        "to": { "const": "removed" },
        "predecessorSourceTree": { "$ref": "#/$defs/sha1" },
        "stagedSourceTree": { "$ref": "#/$defs/sha1" },
        "sourceEvidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence" } },
        "predecessorLedger": { "$ref": "#/$defs/predecessorLedger" },
        "previousTransitionHash": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
        "transitionHash": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
