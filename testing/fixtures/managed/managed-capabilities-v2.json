{
  "contract_version": "managed-capabilities-v2",
  "status": "available",
  "disclosure_version": null,
  "cache_ttl_seconds": 300,
  "capabilities": [
    {
      "alias": "systemsculpt/chat",
      "endpoint": "/api/v1/chat/completions",
      "mode": "stream",
      "availability": "available",
      "auth": "license",
      "metering": "metered_turn",
      "cancellation_supported": false,
      "background_eligible": false,
      "limits": {
        "image_mime_types": "image/png,image/jpeg,image/webp",
        "max_request_bytes": 100663296,
        "max_delta_request_bytes": 25165824,
        "max_messages_on_create": 255,
        "max_messages_per_delta": 16,
        "max_session_messages": 256,
        "max_content_blocks_per_message": 16,
        "max_images_per_turn": 6,
        "max_images_on_create": 64,
        "max_session_images": 64,
        "max_image_bytes": 6291456,
        "max_total_image_bytes": 16777216,
        "max_total_image_bytes_on_create": 67108864,
        "max_text_bytes_per_block": 1048576,
        "max_total_text_bytes": 2097152,
        "max_total_text_bytes_on_create": 16777216,
        "max_tools": 64,
        "max_tools_json_bytes": 524288,
        "max_active_sessions_per_user": 20,
        "max_session_attachment_bytes": 67108864,
        "max_session_stored_json_bytes": 16777216,
        "max_idempotency_key_chars": 128,
        "session_ttl_days": 30,
        "pending_turn_lease_seconds": 300
      },
      "request_contracts": [
        {
          "capability": "chat_turn",
          "header": "x-systemsculpt-capability",
          "header_value": "chat_turn",
          "background_eligible": false,
          "purpose": {
            "presence": "forbidden",
            "values": []
          },
          "cancellation_supported": false,
          "request": {
            "method": "POST",
            "path": "/api/v1/chat/completions",
            "required_headers": [
              "x-license-key",
              "x-plugin-version",
              "x-systemsculpt-contract",
              "x-systemsculpt-capability",
              "idempotency-key"
            ],
            "body": {
              "schema": "managed_chat_request_v1",
              "required_fields": [
                "model",
                "messages",
                "stream"
              ],
              "optional_fields": [
                "tools",
                "tool_choice",
                "plugins",
                "session"
              ],
              "additional_properties": false,
              "model": "ai-agent",
              "stream": true,
              "messages": "managed_chat_messages_v1",
              "tools": "managed_chat_tools_v1",
              "tool_choice": [
                "auto",
                "none",
                "required"
              ],
              "plugins": "managed_chat_plugins_v1",
              "session": "managed_chat_session_v1"
            },
            "definitions": {
              "managed_chat_messages_v1": {
                "type": "non_empty_array",
                "additional_properties": false,
                "roles": {
                  "user": {
                    "required_fields": [
                      "role",
                      "content"
                    ],
                    "optional_fields": [],
                    "content": "string|managed_chat_user_content_blocks_v1"
                  },
                  "assistant": {
                    "required_fields": [
                      "role"
                    ],
                    "optional_fields": [
                      "content",
                      "tool_calls"
                    ],
                    "content": "string",
                    "at_least_one": [
                      "content",
                      "tool_calls"
                    ],
                    "tool_calls": "managed_chat_tool_calls_v1"
                  },
                  "tool": {
                    "required_fields": [
                      "role",
                      "tool_call_id",
                      "content"
                    ],
                    "optional_fields": [
                      "name"
                    ],
                    "content": "string"
                  }
                },
                "user_content_blocks": {
                  "text": {
                    "required_fields": [
                      "type",
                      "text"
                    ],
                    "optional_fields": [],
                    "type_values": [
                      "text",
                      "input_text"
                    ]
                  },
                  "image_url": {
                    "required_fields": [
                      "type",
                      "image_url"
                    ],
                    "optional_fields": [],
                    "image_url": {
                      "required_fields": [
                        "url"
                      ],
                      "optional_fields": [],
                      "url": "data_url"
                    }
                  },
                  "input_image": {
                    "required_fields": [
                      "type",
                      "image_url"
                    ],
                    "optional_fields": [],
                    "image_url": "data_url"
                  }
                },
                "tool_calls": {
                  "required_fields": [
                    "id",
                    "type",
                    "function"
                  ],
                  "optional_fields": [],
                  "type": "function",
                  "function": {
                    "required_fields": [
                      "name",
                      "arguments"
                    ],
                    "optional_fields": [],
                    "arguments": {
                      "wire_type": "string",
                      "encoding": "json",
                      "decoded_type": "non_array_object"
                    }
                  }
                }
              },
              "managed_chat_tools_v1": {
                "type": "array",
                "additional_properties": false,
                "item": {
                  "required_fields": [
                    "type",
                    "function"
                  ],
                  "optional_fields": [],
                  "type": "function",
                  "function": {
                    "required_fields": [
                      "name"
                    ],
                    "optional_fields": [
                      "description",
                      "parameters"
                    ],
                    "description": "string",
                    "parameters": "json_schema_object"
                  }
                }
              },
              "managed_chat_plugins_v1": {
                "type": "array",
                "min_items": 1,
                "max_items": 1,
                "additional_properties": false,
                "items": {
                  "required_fields": ["id"],
                  "optional_fields": [],
                  "id": ["web"]
                },
                "scope": "active_agent_turn",
                "tool_result_continuation": "server_inherit_or_exact_match",
                "new_user_turn_behavior": "reset_unless_explicit"
              },
              "managed_chat_session_v1": {
                "type": "object",
                "one_of": [
                  {
                    "shape": "create",
                    "required_fields": ["mode"],
                    "optional_fields": [],
                    "mode": "create"
                  },
                  {
                    "shape": "resume",
                    "required_fields": ["id", "revision"],
                    "optional_fields": [],
                    "id": "mchat_<32 lowercase hex>",
                    "revision": "nonnegative_integer"
                  }
                ],
                "absence_behavior": "full_history_compatibility",
                "create_behavior": "full_history_snapshot_and_pin_tools",
                "resume_behavior": "delta_user_or_tool_messages_only"
              }
            }
          },
          "response": {
            "status": 200,
            "content_type": "text/event-stream",
            "request_id_header": "x-request-id",
            "session_id_header": "x-systemsculpt-session-id",
            "session_revision_header": "x-systemsculpt-session-revision",
            "frame_delimiter": "\n\n",
            "data_prefix": "data: ",
            "json_frames": [
              "managed_chat_delta_v1",
              "managed_chat_session_commit_v1",
              "managed_chat_error_v1"
            ],
            "definitions": {
              "managed_chat_delta_v1": {
                "format": "openai_chat_completion_chunk",
                "model_alias": "systemsculpt/ai-agent",
                "allowed_delta_fields": [
                  "role",
                  "content",
                  "tool_calls"
                ],
                "implementation_identity_forbidden": true
              },
              "managed_chat_error_v1": {
                "required_fields": [
                  "error"
                ],
                "error_required_fields": [
                  "code",
                  "message"
                ],
                "error_optional_fields": [
                  "session_id",
                  "current_revision",
                  "retry_same_idempotency_key"
                ],
                "bounded": true,
                "implementation_identity_forbidden": true
              },
              "managed_chat_session_commit_v1": {
                "required_fields": ["object", "session_id", "revision", "state"],
                "object": "systemsculpt.chat.session",
                "revision": "positive_integer",
                "state": "committed"
              }
            },
            "successful_terminal_marker": "data: [DONE]\n\n",
            "successful_terminal_marker_count": 1,
            "terminal_failures": [
              {
                "code": "malformed_frame",
                "retry_same_idempotency_key": false
              },
              {
                "code": "missing_terminal_marker",
                "retry_same_idempotency_key": false
              },
              {
                "code": "empty_successful_stream",
                "retry_same_idempotency_key": false
              },
              {
                "code": "in_stream_error",
                "retry_same_idempotency_key": "error_frame_boolean"
              }
            ],
            "cancellation_behavior": "client_abort_stops_waiting_server_work_may_continue"
          },
          "errors": {
            "statuses": [
              400,
              401,
              403,
              402,
              404,
              409,
              410,
              426,
              429,
              502,
              503
            ],
            "conflict_codes": [
              "operation_in_progress",
              "operation_already_completed",
              "operation_terminal",
              "settlement_pending"
            ],
            "session_codes": [
              "session_not_found",
              "session_expired",
              "session_revision_conflict",
              "session_turn_conflict",
              "session_limit_exceeded",
              "session_storage_limit_exceeded",
              "session_state_unavailable",
              "session_storage_unavailable",
              "session_turn_superseded",
              "session_finalization_failed",
              "idempotency_key_reused"
            ],
            "bounded_first_party_messages": true
          }
        },
        {
          "capability": "text_generation",
          "header": "x-systemsculpt-capability",
          "header_value": "text_generation",
          "background_eligible": true,
          "purpose": {
            "presence": "required",
            "values": [
              "transcript_postprocess",
              "workflow_automation"
            ]
          }
        }
      ]
    },
