{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "obsidian": [
        "./src/shims/obsidian.ts"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "remotion.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
